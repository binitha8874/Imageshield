# ImageShield — Environment Variables
# Rename this file to .env and fill in your values

# ── SERVER ──────────────────────────────
PORT=4000

# ── FIREBASE ────────────────────────────
# Download your Firebase Admin SDK key from:
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Save it as serviceAccountKey.json in the project root
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ── GMAIL SMTP (App Password) ────────────
# Enable 2FA on your Gmail, then create an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_EMAIL=youremail@gmail.com
SMTP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── TWILIO SMS ────────────────────────────
# Get credentials at https://console.twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_FROM=+1xxxxxxxxxx
